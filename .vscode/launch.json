{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Turtle Project",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\turtle_draw.exe",
      "args": [
        "${workspaceFolder}\\scripts\\sample_script.txt",
        "${workspaceFolder}\\output\\output.ppm"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": true,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\TDM-GCC-64\\bin\\gdb.exe",
      "preLaunchTask": "build turtle project",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "f:/My Learn/CPP_Final Project/CoreTech_CPP_FinalProject",
      "program": "f:/My Learn/CPP_Final Project/CoreTech_CPP_FinalProject/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}